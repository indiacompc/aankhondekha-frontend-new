# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# public: commit the (small) images so they deploy, but keep heavy media out
# of git — these folders/types are multi-GB and exceed GitHub's file limits.
# Host videos on a CDN / Firebase Storage instead.
/public/videos/
/public/vid/
/public/dash/
/public/data/
/public/Store/
/public/backgrounds/
*.mp4
*.m4s
*.mpd
*.sql
Thumbs.db

# Firebase service account keys — SECRET, never commit
*firebase-adminsdk*.json
serviceAccount*.json
*-service-account*.json
