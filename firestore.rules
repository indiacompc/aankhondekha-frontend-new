rules_version = '2';

// Aankhon Dekha — Firestore security rules.
// Paste into Firebase Console → Firestore → Rules → Publish,
// or deploy with the Firebase CLI (`firebase deploy --only firestore:rules`).

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // An admin is anyone with a doc in /admins keyed by their uid.
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Reference data: anyone may read; only admins may change.
    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ticketTypes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Slots: readable by all. Capacity is decremented client-side during the
    // booking transaction, so any signed-in user may update; create/delete is
    // admin-only. (For stricter control, move booking to a Cloud Function.)
    match /slots/{id} {
      allow read: if true;
      allow update: if signedIn();
      allow create, delete: if isAdmin();
    }

    // Customer profiles: each user owns their own doc; admins may read.
    match /customers/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if signedIn() && request.auth.uid == uid;
    }

    // Tickets: a user may create their own and read their own; admins read all
    // and perform check-in (the only field that flips is isValid).
    match /tickets/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // Admin records: an admin can read their own doc. Writes happen via the
    // seed/admin SDK only (no client writes).
    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
